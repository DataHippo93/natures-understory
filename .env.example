# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Nature's Storehouse
NATURES_STOREHOUSE_MID=YOUR_MID_HERE
NATURES_STOREHOUSE_TOKEN=YOUR_MERCHANT_TOKEN_HERE

# Adirondack Fragrance Farm
ADK_FRAGRANCE_MID=YOUR_MID_HERE
ADK_FRAGRANCE_TOKEN=YOUR_MERCHANT_TOKEN_HERE

# Homebase (optional — synthetic data used until key is available)
HOMEBASE_API_KEY=YOUR_KEY_HERE
HOMEBASE_LOCATION_ID=YOUR_LOCATION_ID_HERE

# LoPro wholesale (Shopify Dev Dashboard app; client credentials grant).
# Client ID/secret live in BWS project natures-storehouse
# (LOPRO_SHOPIFY_CLIENT_ID / LOPRO_SHOPIFY_CLIENT_SECRET).
LOPRO_SHOPIFY_SHOP=0xdj5s-hq.myshopify.com
LOPRO_SHOPIFY_API_VERSION=2026-04
LOPRO_SHOPIFY_CLIENT_ID=YOUR_CLIENT_ID_HERE
LOPRO_SHOPIFY_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
WHOLESALE_T1_PRICE_LIST_ID=gid://shopify/PriceList/34822914295
WHOLESALE_T2_PRICE_LIST_ID=gid://shopify/PriceList/34823045367
